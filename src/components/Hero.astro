---
import { profile, socials } from '../data/portfolio';
import Social from './Social.astro';
---

<section id="top" class="hero">
  <div class="container hero-inner">
    <p class="eyebrow reveal">$ whoami</p>

    <h1 class="reveal">
      Hi, I'm <span class="name">{profile.name}</span>
    </h1>

    <h2 class="role reveal">
      <span class="typed" data-words={JSON.stringify(profile.taglines)}></span
      ><span class="caret">▋</span>
    </h2>

    <p class="lead reveal">{profile.summary}</p>

    <div class="cta-row reveal">
      <a href="#projects" class="btn btn-primary">View my work</a>
      <a href="#contact" class="btn btn-ghost">Contact me</a>
    </div>

    <div class="hero-socials reveal">
      {socials.map((s) => <Social social={s} />)}
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <span></span>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 68px);
    display: flex;
    align-items: center;
    padding-block: 4rem;
  }
  .hero-inner {
    max-width: 800px;
  }
  h1 {
    font-size: clamp(2.4rem, 7vw, 4.25rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }
  .name {
    background: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .role {
    font-size: clamp(1.2rem, 3.5vw, 1.9rem);
    font-weight: 600;
    color: var(--text-muted);
    font-family: var(--mono);
    margin-bottom: 1.5rem;
    min-height: 1.6em;
  }
  .typed {
    color: var(--text);
  }
  .caret {
    color: var(--accent);
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  .lead {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 62ch;
    margin-bottom: 2rem;
  }
  .cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }
  .btn {
    padding: 0.8rem 1.6rem;
    border-radius: 99px;
    font-weight: 600;
    font-size: 0.98rem;
    transition: all 0.22s ease;
    border: 1px solid transparent;
  }
  .btn-primary {
    background: var(--gradient);
    color: #05080f;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px -8px var(--accent-glow);
  }
  .btn-ghost {
    border-color: var(--border);
    color: var(--text);
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .hero-socials {
    display: flex;
    gap: 0.85rem;
  }

  .scroll-hint {
    position: absolute;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    width: 26px;
    height: 42px;
    border: 2px solid var(--border);
    border-radius: 99px;
    display: flex;
    justify-content: center;
    padding-top: 7px;
  }
  .scroll-hint span {
    width: 4px;
    height: 8px;
    background: var(--accent);
    border-radius: 99px;
    animation: scrolldot 1.6s ease-in-out infinite;
  }
  @keyframes scrolldot {
    0% {
      transform: translateY(0);
      opacity: 1;
    }
    100% {
      transform: translateY(14px);
      opacity: 0;
    }
  }
  @media (max-width: 720px) {
    .scroll-hint {
      display: none;
    }
  }
</style>

<script>
  // Lightweight typewriter for the hero tagline.
  const el = document.querySelector<HTMLElement>('.typed');
  if (el) {
    const words: string[] = JSON.parse(el.dataset.words || '[]');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce || words.length === 0) {
      el.textContent = words[0] ?? '';
    } else {
      let w = 0;
      let i = 0;
      let deleting = false;

      const tick = () => {
        const word = words[w];
        el.textContent = word.slice(0, i);

        if (!deleting && i < word.length) {
          i++;
          setTimeout(tick, 70);
        } else if (!deleting && i === word.length) {
          deleting = true;
          setTimeout(tick, 1800);
        } else if (deleting && i > 0) {
          i--;
          setTimeout(tick, 35);
        } else {
          deleting = false;
          w = (w + 1) % words.length;
          setTimeout(tick, 350);
        }
      };
      tick();
    }
  }
</script>
